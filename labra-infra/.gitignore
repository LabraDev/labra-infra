# Ignore Terraform working directories and provider/plugin caches.
**/.terraform/*

# Ignore Terraform state files (local state should never be committed).
*.tfstate
*.tfstate.*

# Ignore crash logs generated by Terraform on unexpected failures.
crash.log
crash.*.log

# Ignore variable override files by default to avoid leaking secrets.
*.tfvars
*.tfvars.json

# Keep examples and the tracked non-secret dev tfvars template.
!terraform.tfvars.example
!env/dev/terraform.tfvars

# Ignore local override files used for machine-specific overrides.
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore local Terraform CLI configuration files.
.terraformrc
terraform.rc
