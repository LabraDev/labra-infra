# Copy this file to backend.hcl, then run:
# terraform init -reconfigure -backend-config=backend.hcl

# S3 bucket created by modules/state-bootstrap.
bucket = "replace-me-labra-infra-dev-tfstate"

# State object key for this environment.
key = "env/dev/terraform.tfstate"

# Region of the S3 backend bucket and DynamoDB table.
region = "us-west-2"

# DynamoDB table created by modules/state-bootstrap.
dynamodb_table = "labra-infra-dev-platform-terraform-locks"

# Encrypt state objects in S3.
encrypt = true
